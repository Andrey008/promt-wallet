{% extends 'base.html.twig' %}

{% block title %}Edit {{ context.title }} - {{ parent() }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('context_index') }}">Contexts</a></li>
        <li class="breadcrumb-item"><a href="{{ path('context_show', {'id': context.id}) }}">{{ context.title }}</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>

<h1 class="mb-4"><i class="bi bi-pencil me-2"></i>Edit Context</h1>

<div class="card">
    <div class="card-body">
        {% include 'context/_form.html.twig' with {
            'button_label': 'Update Context',
            'cancel_url': path('context_show', {'id': context.id})
        } %}
    </div>
</div>
{% endblock %}
