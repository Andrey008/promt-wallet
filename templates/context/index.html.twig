{% extends 'base.html.twig' %}

{% block title %}Contexts - {{ parent() }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-file-text me-2"></i>Contexts</h1>
    <div class="d-flex gap-2">
        <a href="{{ path('context_search') }}" class="btn btn-outline-secondary">
            <i class="bi bi-search me-1"></i> Search
        </a>
        <a href="{{ path('context_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> New Context
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Scope</label>
                <select name="scope" class="form-select" onchange="this.form.submit()">
                    <option value="">All</option>
                    <option value="global" {{ currentScope == 'global' ? 'selected' : '' }}>Global only</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Project</label>
                <select name="project" class="form-select" onchange="this.form.submit()">
                    <option value="">All projects</option>
                    {% for project in projects %}
                        <option value="{{ project.id }}" {{ currentProject == project.id ? 'selected' : '' }}>
                            {{ project.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                {% if currentScope or currentProject %}
                    <a href="{{ path('context_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i> Clear filters
                    </a>
                {% endif %}
            </div>
        </form>
    </div>
</div>

{% if contexts|length > 0 %}
    <div class="list-group">
        {% for context in contexts %}
            <a href="{{ path('context_show', {'id': context.id}) }}" class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between align-items-start">
                    <div>
                        <h5 class="mb-1">
                            {{ context.title }}
                            <span class="badge scope-badge {{ context.scope == 'global' ? 'bg-info' : 'bg-success' }} ms-2">
                                {{ context.scope }}
                            </span>
                        </h5>
                        <small class="text-muted d-block mb-2">
                            {% if context.project %}
                                <i class="bi bi-folder me-1"></i>{{ context.project.name }}
                            {% else %}
                                <i class="bi bi-globe me-1"></i>Available globally
                            {% endif %}
                        </small>
                        <p class="mb-1 text-muted small">
                            {{ context.content|length > 150 ? context.content|slice(0, 150) ~ '...' : context.content }}
                        </p>
                        {% if context.tags|length > 0 %}
                            <div class="mt-2">
                                {% include 'partials/_tag_badges.html.twig' with {'tags': context.tags} %}
                            </div>
                        {% endif %}
                    </div>
                    <small class="text-muted text-nowrap ms-3">
                        #{{ context.sortOrder }}
                    </small>
                </div>
            </a>
        {% endfor %}
    </div>
{% else %}
    <div class="empty-state">
        <i class="bi bi-file-text-fill d-block"></i>
        <h5>No contexts found</h5>
        <p class="text-muted">
            {% if currentScope or currentProject %}
                No contexts match your filter criteria.
            {% else %}
                Create your first context to start building your prompt library.
            {% endif %}
        </p>
        <a href="{{ path('context_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Create Context
        </a>
    </div>
{% endif %}
{% endblock %}
