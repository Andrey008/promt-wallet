{{ form_start(form) }}
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                {{ form_row(form.title) }}
            </div>

            <div class="mb-3">
                {{ form_row(form.content, {'attr': {'data-easymde': true}}) }}
            </div>
        </div>

        <div class="col-md-4">
            <div class="mb-3">
                {{ form_row(form.scope) }}
            </div>

            <div class="mb-3">
                {{ form_row(form.project) }}
            </div>

            <div class="mb-3">
                {{ form_row(form.sortOrder) }}
            </div>

            <div class="mb-3">
                {{ form_row(form.tagsString) }}
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> {{ button_label|default('Save') }}
        </button>
        <a href="{{ cancel_url|default(path('context_index')) }}" class="btn btn-outline-secondary">
            Cancel
        </a>
    </div>
{{ form_end(form) }}

{% block javascripts %}
<script>
    // Toggle project field based on scope
    document.addEventListener('DOMContentLoaded', function() {
        const scopeField = document.querySelector('#context_scope');
        const projectField = document.querySelector('#context_project');
        const projectContainer = projectField ? projectField.closest('.mb-3') : null;

        function toggleProjectField() {
            if (projectContainer) {
                if (scopeField.value === 'global') {
                    projectContainer.style.opacity = '0.5';
                    projectField.required = false;
                } else {
                    projectContainer.style.opacity = '1';
                    projectField.required = true;
                }
            }
        }

        if (scopeField) {
            scopeField.addEventListener('change', toggleProjectField);
            toggleProjectField();
        }
    });
</script>
{% endblock %}
