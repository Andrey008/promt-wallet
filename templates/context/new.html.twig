{% extends 'base.html.twig' %}

{% block title %}New Context - {{ parent() }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('context_index') }}">Contexts</a></li>
        <li class="breadcrumb-item active">New</li>
    </ol>
</nav>

<h1 class="mb-4"><i class="bi bi-file-earmark-plus me-2"></i>New Context</h1>

<div class="card">
    <div class="card-body">
        {% include 'context/_form.html.twig' with {
            'button_label': 'Create Context',
            'cancel_url': path('context_index')
        } %}
    </div>
</div>
{% endblock %}
