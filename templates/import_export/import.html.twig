{% extends 'base.html.twig' %}

{% block title %}Import Data - {{ parent() }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-upload me-2"></i>Import Data</h1>
    <a href="{{ path('import_export_export') }}" class="btn btn-outline-secondary">
        <i class="bi bi-download me-1"></i> Export
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <p class="text-muted">Upload a previously exported JSON or YAML file to import your data.</p>

                <form method="post" action="{{ path('import_export_do_import') }}" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="import_file" class="form-label">File</label>
                        <input type="file" class="form-control" id="import_file" name="import_file" accept=".json,.yaml,.yml" required>
                        <small class="text-muted">Accepted formats: .json, .yaml, .yml</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Conflict Strategy</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="strategy" id="strategy-skip" value="skip" checked>
                            <label class="form-check-label" for="strategy-skip">
                                Skip <small class="text-muted">- keep existing items, only add new ones</small>
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="strategy" id="strategy-overwrite" value="overwrite">
                            <label class="form-check-label" for="strategy-overwrite">
                                Overwrite <small class="text-muted">- update existing items with imported data</small>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-upload me-1"></i> Import
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
