{% extends 'base.html.twig' %}

{% block title %}Register - {{ app_name }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">Create Account</h3>

                {{ form_start(registrationForm) }}
                    <div class="mb-3">
                        {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.displayName, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.displayName, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(registrationForm.displayName) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3">
                        <i class="bi bi-person-plus me-1"></i> Register
                    </button>
                {{ form_end(registrationForm) }}

                <div class="text-center">
                    <span class="text-muted small">Already have an account?</span>
                    <a href="{{ path('app_login') }}" class="text-decoration-none small">Sign in</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
