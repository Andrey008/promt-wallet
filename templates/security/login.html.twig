{% extends 'base.html.twig' %}

{% block title %}Login - {{ app_name }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">
                    <i class="bi bi-journal-code me-2"></i>{{ app_name }}
                </h3>

                {% if error %}
                    <div class="alert alert-danger">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label for="inputEmail" class="form-label">Email</label>
                        <input type="email" value="{{ last_username }}" name="_username" id="inputEmail"
                               class="form-control" autocomplete="email" required autofocus
                               placeholder="your@email.com">
                    </div>

                    <div class="mb-3">
                        <label for="inputPassword" class="form-label">Password</label>
                        <input type="password" name="_password" id="inputPassword"
                               class="form-control" autocomplete="current-password" required>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe" name="_remember_me">
                        <label class="form-check-label" for="rememberMe">Remember me</label>
                    </div>

                    <button class="btn btn-primary w-100 mb-3" type="submit">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Sign in
                    </button>
                </form>

                <div class="text-center">
                    <a href="{{ path('app_forgot_password_request') }}" class="text-decoration-none small">
                        Forgot your password?
                    </a>
                </div>

                <hr>

                <div class="text-center">
                    <span class="text-muted small">Don't have an account?</span>
                    <a href="{{ path('app_register') }}" class="text-decoration-none small">Register</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
