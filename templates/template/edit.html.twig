{% extends 'base.html.twig' %}

{% block title %}Edit {{ template.title }} - {{ parent() }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('template_index') }}">Templates</a></li>
        <li class="breadcrumb-item"><a href="{{ path('template_show', {'id': template.id}) }}">{{ template.title }}</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>

<h1 class="mb-4"><i class="bi bi-pencil me-2"></i>Edit Template</h1>

<div class="card">
    <div class="card-body">
        {% include 'template/_form.html.twig' with {
            'button_label': 'Update Template',
            'cancel_url': path('template_show', {'id': template.id}),
            'placeholders': placeholders
        } %}
    </div>
</div>
{% endblock %}
