{% extends 'base.html.twig' %}

{% block title %}{{ template.title }} - {{ parent() }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('template_index') }}">Templates</a></li>
        <li class="breadcrumb-item active">{{ template.title }}</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1>
            {{ template.title }}
            <span class="badge bg-secondary ms-2">{{ template.targetModelLabel }}</span>
        </h1>
        {% if template.description %}
            <p class="text-muted">{{ template.description }}</p>
        {% endif %}
        {% if template.tags|length > 0 %}
            <div class="mb-3">
                {% include 'partials/_tag_badges.html.twig' with {'tags': template.tags} %}
            </div>
        {% endif %}
    </div>
    <div class="btn-group">
        <a href="{{ path('compose_index', {'template': template.id}) }}" class="btn btn-primary">
            <i class="bi bi-magic me-1"></i> Use Template
        </a>
        <a href="{{ path('template_edit', {'id': template.id}) }}" class="btn btn-outline-primary">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash me-1"></i> Delete
        </button>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Template Body -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-code me-2"></i>Template Body</span>
                <button type="button" class="btn btn-sm btn-outline-primary btn-copy" data-copy-target="#template-body">
                    <i class="bi bi-clipboard me-1"></i> Copy
                </button>
            </div>
            <div class="card-body">
                <pre class="mb-0" id="template-body"><code>{{ template.body }}</code></pre>
            </div>
        </div>

        <!-- Preview -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-eye me-2"></i>Preview (with sample data)
            </div>
            <div class="card-body">
                <pre class="mb-0 bg-light p-3 rounded"><code>{{ preview }}</code></pre>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-info-circle me-2"></i>Template Info
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Target Model</span>
                    <span class="badge bg-secondary">{{ template.targetModelLabel }}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Created</span>
                    <span>{{ template.createdAt|date('M d, Y') }}</span>
                </li>
                {% if template.updatedAt %}
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Updated</span>
                        <span>{{ template.updatedAt|date('M d, Y') }}</span>
                    </li>
                {% endif %}
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Length</span>
                    <span>{{ template.body|length }} chars</span>
                </li>
            </ul>
        </div>

        {% if placeholders|length > 0 %}
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-braces me-2"></i>Used Placeholders
                </div>
                <ul class="list-group list-group-flush">
                    {% for placeholder in placeholders %}
                        <li class="list-group-item">
                            <code>{{ '{{' ~ placeholder ~ '}}' }}</code>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Template</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>{{ template.title }}</strong>?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form action="{{ path('template_delete', {'id': template.id}) }}" method="post" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ template.id) }}">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
