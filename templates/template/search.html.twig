{% extends 'base.html.twig' %}

{% block title %}Search Templates - {{ parent() }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('template_index') }}">Templates</a></li>
        <li class="breadcrumb-item active">Search</li>
    </ol>
</nav>

<h1 class="mb-4"><i class="bi bi-search me-2"></i>Search Templates</h1>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" action="{{ path('template_search') }}">
            <div class="input-group">
                <input type="text" name="q" class="form-control form-control-lg"
                       placeholder="Search in titles, body, and description..."
                       value="{{ query }}" autofocus>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search me-1"></i> Search
                </button>
            </div>
            <small class="text-muted">Minimum 2 characters</small>
        </form>
    </div>
</div>

{% if query %}
    <p class="text-muted mb-3">
        Found {{ templates|length }} result{{ templates|length != 1 ? 's' : '' }} for "{{ query }}"
    </p>

    {% if templates|length > 0 %}
        <div class="list-group">
            {% for template in templates %}
                <a href="{{ path('template_show', {'id': template.id}) }}" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">
                            {{ template.title }}
                            <span class="badge bg-secondary ms-2">{{ template.targetModelLabel }}</span>
                        </h5>
                    </div>
                    {% if template.description %}
                        <small class="text-muted d-block">{{ template.description }}</small>
                    {% endif %}
                    <p class="mb-1 mt-2">
                        <code class="small">{{ template.body|length > 150 ? template.body|slice(0, 150) ~ '...' : template.body }}</code>
                    </p>
                    {% if template.tags|length > 0 %}
                        <div class="mt-2">
                            {% include 'partials/_tag_badges.html.twig' with {'tags': template.tags} %}
                        </div>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            No templates found matching "{{ query }}".
        </div>
    {% endif %}
{% endif %}
{% endblock %}
