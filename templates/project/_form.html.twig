{{ form_start(form) }}
    <div class="mb-3">
        {{ form_row(form.name) }}
    </div>

    <div class="mb-3">
        {{ form_row(form.description) }}
    </div>

    <div class="mb-3">
        {{ form_row(form.stackString) }}
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> {{ button_label|default('Save') }}
        </button>
        <a href="{{ cancel_url|default(path('project_index')) }}" class="btn btn-outline-secondary">
            Cancel
        </a>
    </div>
{{ form_end(form) }}
