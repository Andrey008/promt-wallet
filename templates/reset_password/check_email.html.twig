{% extends 'base.html.twig' %}

{% block title %}Check Your Email - {{ app_name }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-4 text-center">
                <i class="bi bi-envelope-check text-primary" style="font-size: 3rem;"></i>
                <h3 class="card-title mt-3 mb-3">Check Your Email</h3>
                <p class="text-muted">
                    If an account matching your email exists, then an email was just sent
                    that contains a link to reset your password.
                </p>
                <p class="text-muted small">
                    This link will expire in {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                </p>

                <a href="{{ path('app_login') }}" class="btn btn-outline-primary mt-2">
                    <i class="bi bi-arrow-left me-1"></i>Back to login
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
