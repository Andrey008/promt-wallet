{% extends 'base.html.twig' %}

{% block title %}{{ snippet.title }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-code-square me-2"></i>{{ snippet.title }}</h1>
    <div>
        <button type="button" class="btn btn-outline-secondary btn-copy" data-copy-target="#snippet-content">
            <i class="bi bi-clipboard me-1"></i> Copy
        </button>
        <a href="{{ path('snippet_edit', {'id': snippet.id}) }}" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-file-text me-2"></i>Content
            </div>
            <div class="card-body">
                <pre class="prompt-preview bg-light p-3 rounded mb-0" id="snippet-content">{{ snippet.content }}</pre>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-info-circle me-2"></i>Details
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">
                    <small class="text-muted d-block">Created</small>
                    {{ snippet.createdAt|date('M d, Y H:i') }}
                </li>
                {% if snippet.updatedAt %}
                <li class="list-group-item">
                    <small class="text-muted d-block">Updated</small>
                    {{ snippet.updatedAt|date('M d, Y H:i') }}
                </li>
                {% endif %}
                <li class="list-group-item">
                    <small class="text-muted d-block">Length</small>
                    {{ snippet.content|length|number_format }} characters
                </li>
            </ul>
        </div>

        <form method="post" action="{{ path('snippet_delete', {'id': snippet.id}) }}" onsubmit="return confirm('Delete this snippet?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ snippet.id) }}">
            <button type="submit" class="btn btn-outline-danger w-100">
                <i class="bi bi-trash me-1"></i> Delete Snippet
            </button>
        </form>
    </div>
</div>
{% endblock %}
