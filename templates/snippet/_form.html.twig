{{ form_start(form) }}
    <div class="mb-3">
        {{ form_row(form.title) }}
    </div>

    <div class="mb-3">
        {{ form_row(form.content) }}
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> {{ button_label|default('Save') }}
        </button>
        <a href="{{ cancel_url|default(path('snippet_index')) }}" class="btn btn-outline-secondary">
            Cancel
        </a>
    </div>
{{ form_end(form) }}
