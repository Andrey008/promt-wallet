{% extends 'base.html.twig' %}

{% block title %}Snippets - {{ parent() }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-code-square me-2"></i>Snippets</h1>
    <a href="{{ path('snippet_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Snippet
    </a>
</div>

{% if snippets|length > 0 %}
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {% for snippet in snippets %}
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">
                    <a href="{{ path('snippet_show', {'id': snippet.id}) }}" class="text-decoration-none">
                        {{ snippet.title }}
                    </a>
                </h5>
                <p class="card-text text-muted small">
                    {{ snippet.content|length > 100 ? snippet.content|slice(0, 100) ~ '...' : snippet.content }}
                </p>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <small class="text-muted">{{ (snippet.updatedAt ?? snippet.createdAt)|date('M d, Y') }}</small>
                <div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy" data-copy-target="#snippet-content-{{ snippet.id }}" title="Copy content">
                        <i class="bi bi-clipboard"></i>
                    </button>
                    <a href="{{ path('snippet_edit', {'id': snippet.id}) }}" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i>
                    </a>
                </div>
            </div>
            <textarea id="snippet-content-{{ snippet.id }}" class="d-none">{{ snippet.content }}</textarea>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="card">
    <div class="empty-state">
        <i class="bi bi-code-square d-block"></i>
        <h5>No snippets yet</h5>
        <p class="text-muted">Create reusable text snippets for quick insertion into your compositions.</p>
        <a href="{{ path('snippet_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Create Your First Snippet
        </a>
    </div>
</div>
{% endif %}
{% endblock %}
